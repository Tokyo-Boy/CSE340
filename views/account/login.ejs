<div class="login-container">
  <form id="loginForm" action="/account/login" method="post">
    <label for="account_email">Email Address:</label>
    <input type="email" name="account_email" id="account_email" required placeholder="Enter valid email address">

    <label for="account_password">Password</label>
    <span>Passwords must be minimum of 12 characters and include 1 capital letter, 1 number and 1 special character.</span>
    <input type="password" name="account_password" id="account_password" required pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{12,}$">

    <button type="button" id="showPassword">Show Password</button>
    
    <button type="submit" class="submitBtn">Login</button>
  </form>

  <p>No account? <a href="/account/register">Sign-up</a></p>
</div>

<script src="/js/showpass.js"></script>

